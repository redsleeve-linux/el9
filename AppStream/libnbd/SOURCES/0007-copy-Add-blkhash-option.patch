+    $DD if=/dev/zero of=$randfile ibs=512 count=1 \
+        oflag=seek_bytes seek=$((RANDOM * 9973)) conv=notrunc
+done
+
+$VG nbdcopy --blkhash=md5/512 $randfile null:
