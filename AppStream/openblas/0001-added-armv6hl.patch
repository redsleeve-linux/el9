From 07126d60706b4a103e292c118aa95738bb740ed0 Mon Sep 17 00:00:00 2001
From: Jacco Ligthart <jacco@redsleeve.org>
Date: Sun, 30 Nov 2025 17:52:59 +0100
Subject: [PATCH] added armv6hl

---
 SPECS/openblas.spec | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/SPECS/openblas.spec b/SPECS/openblas.spec
index 5fb570e..1c789b7 100644
--- a/SPECS/openblas.spec
+++ b/SPECS/openblas.spec
@@ -15,7 +15,7 @@
 
 Name:           openblas
 Version:        0.3.29
-Release:        1%{?dist}
+Release:        1%{?dist}.redsleeve
 Summary:        An optimized BLAS library based on GotoBLAS2
 License:        BSD-3-Clause
 URL:            https://github.com/OpenMathLib/OpenBLAS
@@ -358,6 +358,9 @@ export AVX="NO_AVX=1 NO_AVX2=1"
 export AVX="NO_AVX2=1"
 %endif
 
+%endif
+%ifarch armv6hl
+TARGET="TARGET=ARMV6 DYNAMIC_ARCH=0"
 %endif
 %ifarch armv7hl
 # ARM v7 still doesn't have runtime cpu detection...
@@ -441,6 +444,9 @@ cp -a %{_includedir}/lapacke %{buildroot}%{_includedir}/%{name}
 # Fix name of libraries: runtime CPU detection has none
 suffix=""
 # but archs that don't have it do have one
+%ifarch armv6hl
+suffix="_armv6"
+%endif
 %ifarch armv7hl
 suffix="_armv7"
 %endif
@@ -653,6 +659,9 @@ rm -rf %{buildroot}%{_libdir}/cmake
 %endif
 
 %changelog
+* Sun Nov 30 2025 Jacco Ligthart <jacco@redsleeve.org> - 0.3.29-1.redsleeve
+- added armv6hl
+
 * Wed Apr 09 2025 Pavel Simovec <psimovec@redhat.com> - 0.3.29-1
 - Update to 0.3.29
 - Resolves: RHEL-77185
-- 
