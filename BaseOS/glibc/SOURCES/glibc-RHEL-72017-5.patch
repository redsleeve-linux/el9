+
+#include <ctype.h>
+
+int
+my_isalpha (int ch)
+{
+  return isalpha (ch);
+}
+
+int
+my_toupper (int ch)
+{
+  return toupper (ch);
+}
+
+int
+my_tolower (int ch)
+{
+  return tolower (ch);
+}
diff --git a/ctype/tst-ctype-tls-skeleton.c b/ctype/tst-ctype-tls-skeleton.c
