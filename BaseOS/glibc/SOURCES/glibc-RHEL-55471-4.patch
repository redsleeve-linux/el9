+
+common_objpfx=$1; shift
+test_program_prefix=$1; shift
+
+status=0
+
+${test_program_prefix} \
+  ${common_objpfx}stdio-common/tst-fwrite-bz29459 \
+    2> ${common_objpfx}stdio-common/tst-fwrite-bz29459.out \
+    | head -n1 > /dev/null
