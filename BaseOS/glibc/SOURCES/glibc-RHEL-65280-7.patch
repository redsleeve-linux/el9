-/* Maximum currently used feature size of the rseq area.  */
-#define RSEQ_AREA_SIZE_MAX_USED 28
-
-/* Minimum alignment of the rseq area.  */
-#define RSEQ_MIN_ALIGN 32
-
-/* Alignment requirement of the rseq area.
