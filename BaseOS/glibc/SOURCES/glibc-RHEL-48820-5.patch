+	 from the global scope.  */
+      if (GL(dl_ns)[LM_ID_BASE].libc_map != NULL)
+	{
+	  RTLD_TIMING_VAR (start);
+	  rtld_timer_start (&start);
+	  _dl_relocate_object_no_relro (&GL(dl_rtld_map), main_map->l_scope, 0, 0);
