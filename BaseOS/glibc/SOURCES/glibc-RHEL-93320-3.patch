diff --git a/elf/rtld.c b/elf/rtld.c
index dac827e249b2fe14..fd70c4c3528cda2d 100644
--- a/elf/rtld.c
+++ b/elf/rtld.c
@@ -380,6 +380,7 @@ struct rtld_global_ro _rtld_global_ro attribute_relro =
     ._dl_catch_error = _dl_catch_error,
