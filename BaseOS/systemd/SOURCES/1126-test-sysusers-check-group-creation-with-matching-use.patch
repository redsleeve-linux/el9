+++ b/test/test-sysusers/test-15.expected-group
@@ -0,0 +1 @@
+root:x:0:
diff --git a/test/test-sysusers/test-15.expected-passwd b/test/test-sysusers/test-15.expected-passwd
new file mode 100644
index 0000000000..a880bd497f
