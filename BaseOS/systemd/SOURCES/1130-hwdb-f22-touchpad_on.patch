---
 hwdb.d/60-keyboard.hwdb | 34 +++++++++++++++++-----------------
 1 file changed, 17 insertions(+), 17 deletions(-)

diff --git a/hwdb.d/60-keyboard.hwdb b/hwdb.d/60-keyboard.hwdb
index df578276b2..c3b4a6bddc 100644
