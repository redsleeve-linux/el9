+        log_debug("/* %s(%s) */", __func__, str);
+        assert_se(parse_timestamp(str, &usec) >= 0);
+        assert_se(usec >= expected);
+        assert_se(usec_sub_unsigned(usec, expected) <= max_diff);
+}
